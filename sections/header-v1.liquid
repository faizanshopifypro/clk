<script>
  document.addEventListener('DOMContentLoaded', function () {
    const hamburgers = document.querySelectorAll('.hamburger-icon');
    const closeBtns = document.querySelectorAll('.close-hamburger');
    const menuPreviews = document.querySelectorAll('.menu-preview');

    // Hamburger click
    hamburgers.forEach((hamburger) => {
      hamburger.addEventListener('click', () => {
        // Only if hamburger is visible
        if (hamburger.offsetParent !== null) {
          menuPreviews.forEach((menu) => menu.classList.add('active'));
          // Hide all hamburgers
          hamburgers.forEach((h) => (h.style.display = 'none'));
          // Show all close buttons
          closeBtns.forEach((c) => {
            c.style.display = 'flex';
            c.style.flexDirection = 'column';
            c.style.alignItems = 'center';
            c.style.gap = '3px';
          });
        }
      });
    });

    // Close click
    closeBtns.forEach((closeBtn) => {
      closeBtn.addEventListener('click', () => {
        if (closeBtn.offsetParent !== null) {
          menuPreviews.forEach((menu) => menu.classList.remove('active'));
          // Hide all close buttons
          closeBtns.forEach((c) => (c.style.display = 'none'));
          // Show all hamburgers
          hamburgers.forEach((h) => (h.style.display = 'flex'));
        }
      });
    });
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const positions = document.querySelectorAll('.postion');

    positions.forEach((position) => {
      position.addEventListener('click', function (e) {
        // Sirf mobile pe toggle
        if (window.innerWidth <= 575) {
          const advice = this.querySelector('.advice-link');
          if (advice) {
            // Toggle display
            if (advice.style.display === 'flex') {
              advice.style.display = 'none';
            } else {
              advice.style.display = 'flex';
              advice.style.flexDirection = 'column';
              advice.style.gap = '10px';
              advice.style.padding = '20px 0';
            }
          }
        }
      });
    });
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const positions = document.querySelectorAll('.postion');

    positions.forEach((position) => {
      position.addEventListener('click', function (e) {
        if (window.innerWidth <= 575) {
          const advice = this.querySelector('.advice-link');
          if (advice) {
            advice.classList.toggle('open');
          }
        }
      });
    });
  });
</script>

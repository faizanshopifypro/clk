  <script>
(function() {
  const originalFetch = window.fetch;
  window.fetch = function(url, options) {
    if (typeof url === 'string' && url.includes('/search/suggest')) {
      const newUrl = new URL(url, window.location.origin);
      // Set limit per resource type
      newUrl.searchParams.set('resources[limit:product]', '8');
      newUrl.searchParams.set('resources[limit:collection]', '4');
      newUrl.searchParams.set('resources[limit:page]', '4');
      newUrl.searchParams.set('resources[limit:article]', '4');
      newUrl.searchParams.set('resources[limit:query]', '4');
      return originalFetch(newUrl.toString(), options);

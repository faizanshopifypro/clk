<script>
(function() {
  const originalFetch = window.fetch;
    let debounceTimer = null;
  const skuCache = {}; // Cache SKUs by handle to avoid refetching

  const RESTRICTED_PRODUCT_TAG = 'GMSMX13';
  const REQUIRED_CUSTOMER_TAG = 'MX13';

  // Same MX13 rule as products: predictive search will not list these collections unless the customer is allowed.
  // Confirm handle: Admin → Collections → open collection → URL is /collections/your-handle
  const RESTRICTED_COLLECTION_HANDLES = ['gms-mx13-restricted-key-system'];
  const RESTRICTED_COLLECTION_TITLES_NORMALIZED = ['gms mx13 restricted key system'];

  function customerMayViewRestrictedProducts() {
    const ctx = window.__predictiveSearchCustomer;
    if (!ctx || !ctx.loggedIn || !Array.isArray(ctx.tags)) return false;
    return ctx.tags.some(function(t) { return String(t).trim() === REQUIRED_CUSTOMER_TAG; });
  }

  // Shopify /products/{handle}.js returns tags as an array, not a comma string.
  function normalizeProductTagList(tags) {
    if (!tags) return [];
    if (Array.isArray(tags)) {
      return tags.map(function(t) { return String(t).trim(); }).filter(Boolean);
    }
    if (typeof tags === 'string') {
      return tags.split(',').map(function(t) { return t.trim(); }).filter(Boolean);
    }
    return [];
  }

  function productHasRestrictedTag(tags) {
    var want = RESTRICTED_PRODUCT_TAG.toLowerCase();
    return normalizeProductTagList(tags).some(function(t) { return t.toLowerCase() === want; });
  }

  function filterProductsByCustomerAccess(products) {
    var allowed = customerMayViewRestrictedProducts();
    return products.filter(function(p) {
      if (!productHasRestrictedTag(p._productTagsCsv)) return true;
      return allowed;
    });
  }

  function collectionHandleFromSuggest(c) {
    if (c && typeof c.handle === 'string' && c.handle.trim()) return c.handle.trim().toLowerCase();
    var url = c && c.url ? String(c.url) : '';
    try {
      var u = new URL(url, window.location.origin);
      var m = u.pathname.match(/\/collections\/([^/?#]+)/);
      return m ? decodeURIComponent(m[1]).toLowerCase() : '';
    } catch (e) {
      return '';
    }
  }

  function normalizeCollectionTitleForMatch(title) {
    return String(title || '').trim().toLowerCase().replace(/\s+/g, ' ');
  }

  function collectionIsMx13Restricted(c) {
    var h = collectionHandleFromSuggest(c);
    if (h && RESTRICTED_COLLECTION_HANDLES.indexOf(h) !== -1) return true;
    var t = normalizeCollectionTitleForMatch(c && c.title);
    if (t && RESTRICTED_COLLECTION_TITLES_NORMALIZED.indexOf(t) !== -1) return true;
    return false;
  }

  function filterCollectionsByCustomerAccess(collections) {
    var allowed = customerMayViewRestrictedProducts();
    return collections.filter(function(c) {
      if (!collectionIsMx13Restricted(c)) return true;
      return allowed;
    });
  }

  // ================================================
  // FETCH SKU BY HANDLE — cached
  // ================================================
  async function fetchProductDetails(handle) {
    if (skuCache[handle]) return skuCache[handle];
    try {
      const res = await originalFetch(`/products/${handle}.js`);
      const data = await res.json();
      const result = {
        sku: data?.variants?.[0]?.sku || '',
        variants: data?.variants || [],
        tags: data?.tags != null ? data.tags : ''
      };
      skuCache[handle] = result;
      return result;
    } catch (e) {
      return { sku: '', variants: [], tags: '' };
    }
  }

  // ================================================
  // FETCH PRODUCTS — SKU first then keyword
  // ================================================
  async function fetchProducts(searchTerm) {
    const [skuRes, kwRes] = await Promise.all([
      originalFetch(`/search/suggest.json?q=${encodeURIComponent(searchTerm)}&resources[type]=product&resources[limit]=5&resources[options][fields]=variants.sku`),
      originalFetch(`/search/suggest.json?q=${encodeURIComponent(searchTerm)}&resources[type]=product&resources[limit]=8&resources[options][fields]=title,product_type,variants.title,vendor,tag`)
    ]);

    const [skuData, kwData] = await Promise.all([skuRes.json(), kwRes.json()]);

    const skuProducts = skuData?.resources?.results?.products || [];
    const kwProducts = kwData?.resources?.results?.products || [];

    // Merge — SKU first, no duplicates
    const seen = new Set();
    const merged = [];
    for (const p of [...skuProducts, ...kwProducts]) {
      if (!seen.has(p.id)) {
        seen.add(p.id);
        merged.push(p);
      }
    }

    // Fetch SKUs for all merged products in parallel
    const details = await Promise.all(
      merged.map(p => fetchProductDetails(p.handle))
    );

    // Attach SKU and variants to each product
    merged.forEach((p, i) => {
      p.sku = details[i].sku;
      p.allVariants = details[i].variants;
      var fromJs = details[i].tags;
      var fromSuggest = p.tags != null ? p.tags : p.tag;
      p._productTagsCsv = normalizeProductTagList(fromJs).concat(normalizeProductTagList(fromSuggest));
    });

    // Re-sort — products whose SKU matches search term come first
    const term = searchTerm.toLowerCase();
    merged.sort((a, b) => {
      const aSkuMatch = a.sku?.toLowerCase().includes(term) ? 0 : 1;
      const bSkuMatch = b.sku?.toLowerCase().includes(term) ? 0 : 1;
      return aSkuMatch - bSkuMatch;
    });

    return filterProductsByCustomerAccess(merged);
  }

  // ================================================
  // FETCH COLLECTIONS / PAGES / ARTICLES
  // ================================================
  async function fetchExtra(searchTerm) {
    const res = await originalFetch(`/search/suggest.json?q=${encodeURIComponent(searchTerm)}&resources[type]=collection,page,article&resources[limit]=5`);
    const data = await res.json();
    return {
      collections: data?.resources?.results?.collections || [],
      pages: data?.resources?.results?.pages || [],
      articles: data?.resources?.results?.articles || []
    };
  }

  // ================================================
  // RENDER EVERYTHING
  // ================================================
  function renderAll(products, collections, pages, articles) {
    const flydown = document.querySelector('.search-flydown--results');
    if (!flydown) return;

    flydown.innerHTML = `<style>
  .search-flydown[data-live-search-flydown]{
      --open-height: auto !important;
  }
  .search-flydown__group-title{
    text-transform: uppercase;
    background: #fafafa !important;
    padding: 6px 12px 5px;
    color: #2226 !important;
    margin: 0;
    font-size: 14px !important;
    font-weight: normal !important;
    font-family: 'Barlow';
    line-height: 20px;
}
.search-flydown--product-title, .search-flydown__list-item a{
    line-height: 20px;
    font-size: 14px !important;
    color: #197bbd !important;
    padding-top: 0;
    padding-bottom: 10px;
    margin-top: 0;
    margin-bottom: 0;
}
.search-flydown--product-title{
font-weight:bold;
}
.search-flydown--product__price{
font-size: 12px !important;
margin:4px 0px !important;
}
.search-flydown--product__price .price__current{
font-size: 12px !important;
}
.search-flydown__continue{
font-size: 14px !important;
}
.search-flydown__continue:focus {
    outline: none !important;
    outline-offset: 0px !important;
}
.search-flydown__no-results{
width:100% !important;
}
@media screen and (min-width:1024px){
.search-flydown--product-items ul.search-flydown__group-list{
  display: grid;
    grid-template-columns: repeat(2, 1fr);
}
.search-flydown--results.visible[data-animation-state="visible"]{
      display: flex;
    flex-direction: row-reverse;
  }
}
@media screen and (max-width:1024px){
.search-flydown__queries-collections{
padding-left:0px !important;
} 
}
</style><div id="shopify-section-predictive-search" class="shopify-section"><div></div></div>`;

    const blogPages = [...pages, ...articles];

    // ── PRODUCTS ──
    if (products.length > 0) {
      const productItems = document.createElement('div');
      productItems.classList.add('search-flydown--product-items');

      const productListHTML = products.map(product => {
        const price = (product.price / 1).toFixed(2);
        const image = product.featured_image?.url || '';
        const sku = product.sku || '';
        return `
          <li>
            <a class="search-flydown--product" href="${product.url}">
              ${image ? `<figure class="search-flydown--product-image">
                <img src="${image}" alt="${product.title}" style="width:70px;height:70px;object-fit:cover;">
              </figure>` : ''}
              <div class="search-flydown--product-text">
                <span class="search-flydown--product-title">${product.title}</span>
                ${sku ? `<p class="search-flydown--product__price">SKU: ${sku}</p>` : ''}
                <div class="price search-flydown--product__price">
                  <div class="price__current">
                    <span class="money">$${price}</span>
                  </div>
                </div>
              </div>
            </a>
          </li>
        `;
      }).join('');

      productItems.innerHTML = `
        <h3 class="search-flydown__group-title">Products</h3>
        <ul class="search-flydown__group-list">${productListHTML}</ul>
      `;
      flydown.appendChild(productItems);
    }

    // ── COLLECTIONS + BLOG & PAGES ──
    if (collections.length > 0 || blogPages.length > 0) {
      const wrapper = document.createElement('div');
      wrapper.classList.add('search-flydown__queries-collections-pages');

      if (collections.length > 0) {
        const section = document.createElement('div');
        section.classList.add('search-flydown__queries-collections');
        section.innerHTML = `
          <h3 class="search-flydown__group-title">Collections</h3>
          <ul class="search-flydown__group-list">
            ${collections.map(c => `
              <li class="search-flydown__list-item">
                <a href="${c.url}">${c.title}</a>
              </li>
            `).join('')}
          </ul>
        `;
        wrapper.appendChild(section);
      }

      if (blogPages.length > 0) {
        const section = document.createElement('div');
        section.classList.add('search-flydown__pages-posts-items');
        section.innerHTML = `
          <h5 class="search-flydown__group-title">Blog & Pages</h5>
          <ul class="search-flydown__group-list search-flydown__pages-posts-items-list">
            ${blogPages.map(item => `
              <li class="search-flydown__list-item">
                <a href="${item.url}">${item.title}</a>
              </li>
            `).join('')}
          </ul>
        `;
        wrapper.appendChild(section);
      }

      flydown.appendChild(wrapper);
    }

    if (products.length === 0 && collections.length === 0 && blogPages.length === 0) {
      flydown.innerHTML += `<p class="search-flydown__no-results">No results found</p>`;
    }
  }

  // ================================================
  // MAIN SEARCH
  // ================================================
  async function runSearch(searchTerm) {
    if (!searchTerm || searchTerm.trim().length === 0) return;

    const [products, { collections, pages, articles }] = await Promise.all([
      fetchProducts(searchTerm),
      fetchExtra(searchTerm)
    ]);

    renderAll(products, filterCollectionsByCustomerAccess(collections), pages, articles);
  }

  // ================================================
  // INTERCEPT THEME FETCH
  // ================================================
  window.fetch = function(url, options) {
    if (typeof url === 'string' && url.includes('/search/suggest')) {
      const urlObj = new URL(url, window.location.origin);
      const searchTerm = urlObj.searchParams.get('q') || '';

      const emptyHTML = `<div id="shopify-section-predictive-search" class="shopify-section"><div></div></div>`;

      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        runSearch(searchTerm);
      }, 250);

      return Promise.resolve(new Response(emptyHTML, {
        status: 200,
        headers: { 'Content-Type': 'text/html' }
      }));
    }

    return originalFetch.apply(this, arguments);
  };

})();
</script>

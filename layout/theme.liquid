   <script>
(function () {

  // Get nearest quantity selector (PER PRODUCT)
  function getSelector(el) {
    return el.closest('[data-quantity-selector]');
  }

  function updateMinusState(selector, input) {
    const minQty = parseInt(selector.dataset.minQuantity, 10) || 1;
    const minusBtn = selector.querySelector('[data-quantity-minus]');
    const minusWrapper = selector.querySelector('[data-button-wrapper-minus]');
    const value = parseInt(input.value, 10) || minQty;

    if (value <= minQty) {
      minusBtn?.setAttribute('disabled', 'disabled');
      minusWrapper?.classList.add('quantity-selector__button-wrapper--disabled');
    } else {
      minusBtn?.removeAttribute('disabled');
      minusWrapper?.classList.remove('quantity-selector__button-wrapper--disabled');
    }
  }

  // 🔹 PLUS / MINUS HANDLER (EVENT DELEGATION → WORKS IN FLICKITY)
  document.addEventListener('click', function (e) {

    const plusBtn  = e.target.closest('[data-quantity-plus]');
    const minusBtn = e.target.closest('[data-quantity-minus]');
    if (!plusBtn && !minusBtn) return;

    const selector = getSelector(e.target);
    if (!selector) return;

    e.preventDefault();

    const input = selector.querySelector('[data-quantity-input]');
    if (!input) return;

    const minQty = parseInt(selector.dataset.minQuantity, 10) || 1;
    const step   = parseInt(selector.dataset.step, 10) || 1;

    let value = parseInt(input.value, 10);
    if (isNaN(value) || value < minQty) value = minQty;

    if (plusBtn)  value += step;
    if (minusBtn) value -= step;

    if (value < minQty) value = minQty;

    input.value = value;
    input.dispatchEvent(new Event('change', { bubbles: true }));

    updateMinusState(selector, input);
  });

  // 🔹 MANUAL INPUT VALIDATION
  document.addEventListener('change', function (e) {
    const input = e.target.closest('[data-quantity-input]');
    if (!input) return;

    const selector = getSelector(input);
    if (!selector) return;

    const minQty = parseInt(selector.dataset.minQuantity, 10) || 1;
    const step   = parseInt(selector.dataset.step, 10) || 1;

    let value = parseInt(input.value, 10);
    if (isNaN(value) || value < minQty) {
      value = minQty;
    }

    input.value = value;
    updateMinusState(selector, input);
  });

  // 🔹 INITIAL STATE FIX (FOR ALL PRODUCTS ON LOAD)
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('[data-quantity-selector]').forEach(selector => {
      const input = selector.querySelector('[data-quantity-input]');
      if (input) updateMinusState(selector, input);
    });
  });

})();
</script>
